TONE_HOST=192.168.1.100
TONE_PORT=50000
TONE_PROFILE=primary
TONE_DISCOVERY_BROADCASTS=255.255.255.255

# Enable writes only for a trusted local session.
# TONE_ENABLE_WRITES=1
# TONE_WRITABLE_SLOTS=1,2,3,4

# Remote write mode is refused unless both values are set.
# TONE_ALLOW_REMOTE_WRITES=1
# TONE_WRITE_TOKEN=change-this-long-random-token
